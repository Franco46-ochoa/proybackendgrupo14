# ===========================================
# SmartMargin AI - Variables de Entorno
# ===========================================

# Auth (JWT)
JWT_SECRET=
BCRYPT_SALT_ROUNDS=10

# Base de Datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartmargin
DB_USER=postgres
DB_PASSWORD=

# MercadoPago (Sandbox)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
WEBHOOK_URL=

# Google OAuth
GOOGLE_CLIENT_ID=

# Gemini API (Google AI Studio)
GEMINI_API_KEY=

# Sentry (Error Monitoring)
SENTRY_DSN=

# Telegram Bot (Reportero)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Puerto del servidor
PORT=3000
